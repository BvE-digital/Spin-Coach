# ─── Frontend (prefix all with VITE_) ───────────────────────────────────────
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_REDIRECT_URI=http://localhost:5173
VITE_D365_SCOPE=https://yourorg.crm.dynamics.com/user_impersonation

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Azure AD (JWT validation + D365 service-to-service)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# D365
D365_RESOURCE=https://yourorg.crm.dynamics.com
D365_API_VERSION=9.2

# AI
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Whisper fallback transcription
OPENAI_API_KEY=

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:5173
